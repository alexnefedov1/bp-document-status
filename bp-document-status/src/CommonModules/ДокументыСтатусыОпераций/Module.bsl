#Область ПрограммныйИнтерфейс

// Имя роли должно совпадать с метаданными конфигурации.
// Реквизит формы (не Объект) — для ввода статуса на проведённых документах БП.
Функция ИмяРеквизитаФормыСтатуса() Экспорт
	Возврат "бпСтатусДокумента";
КонецФункции

Функция ИмяРолиИзменениеСтатуса() Экспорт
	Возврат "ИзменениеСтатусаОперационныхДокументов";
КонецФункции

Функция ЕстьПравоИзмененияСтатусаДокумента() Экспорт
	Возврат РольДоступна(ИмяРолиИзменениеСтатуса());
КонецФункции

Функция ЗначениеСтатусаПоУмолчанию() Экспорт
	Возврат Перечисления.СтатусыДокументовОпераций.ВРаботе;
КонецФункции

Функция СтатусВыполнено() Экспорт
	Возврат Перечисления.СтатусыДокументовОпераций.Выполнено;
КонецФункции

// ИмяДокументаМетаданных — строка, в поставке: "РеализацияТоваровУслуг", "ПоступлениеТоваровУслуг".
// РежимЗаписи — необязательно: из ПередЗаписью(..., РежимЗаписи, ...); при проведении ТЧ могут пересчитаться типовым кодом,
//               поэтому при «Выполнено» сравнение с эталоном из БД для контроля «только статус» выполняется без ТЧ.
Процедура ПередЗаписьюДокументаСоСтатусом(Отказ, ТекущийОбъект, ИмяДокументаМетаданных, РежимЗаписи = Неопределено) Экспорт
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	СтатусВБазе = Неопределено;
	Если Не ТекущийОбъект.ЭтоНовый() Тогда
		СтатусВБазе = СтатусДокументаИзБазы(ТекущийОбъект.Ссылка, ИмяДокументаМетаданных);
	КонецЕсли;
	
	// 1) Обмен: документ «Выполнено» в БП не принимает и не отдаёт изменения.
	Если ТекущийОбъект.ОбменДанными.Загрузка Тогда
		
		Если Не ТекущийОбъект.ЭтоНовый() И СтатусВБазе = СтатусВыполнено() Тогда
			Отказ = Истина;
			Сообщить(ТекстБлокировкиОбменаДляСтатусаВыполнено());
			Возврат;
		КонецЕсли;
		
		// Статус в БП не перезаписывается данными из сообщения (для прочих статусов).
		Если СтатусВБазе <> Неопределено Тогда
			ТекущийОбъект.СтатусДокумента = СтатусВБазе;
		Иначе
			ТекущийОбъект.СтатусДокумента = ЗначениеСтатусаПоУмолчанию();
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;
	
	// 2) Интерактив и прочие записи (не загрузка) — контроль смены статуса и блокировка «Выполнено».
	Если Не ТекущийОбъект.ОбменДанными.Загрузка Тогда
		
		// Без роли статус всегда эталонный (из БД или «В работе» для нового) — нельзя подменить через форму/API.
		ЗафиксироватьСтатусБезПраваИзменения(ТекущийОбъект);
		
		Если Не ТекущийОбъект.ЭтоНовый() Тогда
			СтатусВБазе = СтатусДокументаИзБазы(ТекущийОбъект.Ссылка, ИмяДокументаМетаданных);
		Иначе
			СтатусВБазе = Неопределено;
		КонецЕсли;
		
		Если СтатусВБазе = Неопределено Тогда
			// Новый документ: допускается только значение по умолчанию без роли.
			Если ТекущийОбъект.СтатусДокумента <> ЗначениеСтатусаПоУмолчанию()
				И Не ЕстьПравоИзмененияСтатусаДокумента() Тогда
				Отказ = Истина;
				Сообщить("Изменять статус документа может только пользователь с ролью """ + ИмяРолиИзменениеСтатуса() + """.");
				Возврат;
			КонецЕсли;
		Иначе
			Если ТекущийОбъект.СтатусДокумента <> СтатусВБазе
				И Не ЕстьПравоИзмененияСтатусаДокумента() Тогда
				Отказ = Истина;
				Сообщить("Изменять статус документа может только пользователь с ролью """ + ИмяРолиИзменениеСтатуса() + """.");
				Возврат;
			КонецЕсли;
			
			Если СтатусВБазе = СтатусВыполнено() Тогда
				Если Не ЕстьПравоИзмененияСтатусаДокумента() Тогда
					Отказ = Истина;
					Сообщить("Документ в статусе ""Выполнено"" недоступен для изменения.");
					Возврат;
				КонецЕсли;
				
				СтарыйОбъект = ТекущийОбъект.Ссылка.ПолучитьОбъект();
				СтарыйОбъект.СтатусДокумента = ТекущийОбъект.СтатусДокумента;
				
				СравниватьТч = Истина;
				Если РежимЗаписи <> Неопределено И РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
					СравниватьТч = Ложь;
				КонецЕсли;
				
				Если Не ДокументыСтруктурноСовпадают(СтарыйОбъект, ТекущийОбъект, ИмяДокументаМетаданных, СравниватьТч) Тогда
					Отказ = Истина;
					Сообщить("При статусе ""Выполнено"" можно изменить только поле ""Статус документа"".");
					Возврат;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	ОтключитьРегистрациюДокументаВОбменеЕслиСтатусВыполнено(ТекущийОбъект, СтатусВБазе);
	
КонецПроцедуры

// Для правил конвертации / отборов плана обмена: Ложь — документ не участвует в обмене.
Функция ДокументУчаствуетВОбменеДанными(СсылкаДокумента) Экспорт
	
	Если СсылкаДокумента = Неопределено Или СсылкаДокумента.Пустая() Тогда
		Возврат Истина;
	КонецЕсли;
	
	Статус = СтатусДокументаИзБазыПоСсылкеДокумента(СсылкаДокумента);
	Возврат Статус <> СтатусВыполнено();
	
КонецФункции

Процедура ПередУдалениемДокументаСоСтатусом(Отказ, ТекущийОбъект, ИмяДокументаМетаданных) Экспорт
	
	Если Отказ Или ТекущийОбъект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	СтатусВБазе = СтатусДокументаИзБазы(ТекущийОбъект.Ссылка, ИмяДокументаМетаданных);
	Если СтатусВБазе = СтатусВыполнено() Тогда
		Отказ = Истина;
		Сообщить("Нельзя удалить документ в статусе ""Выполнено"". Сначала смените статус (роль """ + ИмяРолиИзменениеСтатуса() + """).");
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьСтатусПоУмолчаниюПриЗаполнении(ТекущийОбъект) Экспорт
	Если Не ЗначениеЗаполнено(ТекущийОбъект.СтатусДокумента) Тогда
		ТекущийОбъект.СтатусДокумента = ЗначениеСтатусаПоУмолчанию();
	КонецЕсли;
КонецПроцедуры

// Статус, который допустим пользователю без роли ИзменениеСтатусаОперационныхДокументов.
Функция ЭталонныйСтатусДокумента(ОбъектДокумента) Экспорт
	
	Если ОбъектДокумента = Неопределено Тогда
		Возврат ЗначениеСтатусаПоУмолчанию();
	КонецЕсли;
	
	Если Не ОбъектДокумента.Ссылка.Пустая() Тогда
		СтатусИзБазы = СтатусДокументаИзБазыПоСсылкеДокумента(ОбъектДокумента.Ссылка);
		Если СтатусИзБазы <> Неопределено Тогда
			Возврат СтатусИзБазы;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЗначениеСтатусаПоУмолчанию();
	
КонецФункции

// Подставить в объект эталонный статус, если у пользователя нет роли на изменение.
Процедура ЗафиксироватьСтатусБезПраваИзменения(ОбъектДокумента) Экспорт
	
	Если ОбъектДокумента = Неопределено Или ЕстьПравоИзмененияСтатусаДокумента() Тогда
		Возврат;
	КонецЕсли;
	
	ОбъектДокумента.СтатусДокумента = ЭталонныйСтатусДокумента(ОбъектДокумента);
	
КонецПроцедуры

// Чтение реквизита СтатусДокумента из БД по ссылке (имя вида документа берётся из ссылки).
Функция СтатусДокументаИзБазыПоСсылкеДокумента(СсылкаДокумента) Экспорт
	
	Если СсылкаДокумента = Неопределено Или СсылкаДокумента.Пустая() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ИмяДок = СсылкаДокумента.Метаданные().Имя;
	Возврат СтатусДокументаИзБазы(СсылкаДокумента, ИмяДок);
	
КонецФункции

// После успешной записи типовая логика иногда сбрасывает в данных формы реквизиты расширения — подтянуть в переданный объект (без вызова методов формы).
// Для отображения на управляемой форме вызывайте из модуля формы бпСтатус_ЗаписатьСтатусИзБазыВРеквизитФормыОбъект (см. snippets/Form_Module_snippet.bsl).
// ТолькоЕслиВОбъектеПусто — Истина: не перезаписывать уже выбранный в форме статус; Ложь — всегда синхронизировать с БД.
Процедура ПодтянутьСтатусДокументаИзБазыВОбъектФормы(ОбъектДокумента, ТолькоЕслиВОбъектеПусто = Ложь) Экспорт
	
	Если ОбъектДокумента = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если ОбъектДокумента.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Если ТолькоЕслиВОбъектеПусто И ЗначениеЗаполнено(ОбъектДокумента.СтатусДокумента) Тогда
		Возврат;
	КонецЕсли;
	
	СтатусИзБазы = СтатусДокументаИзБазыПоСсылкеДокумента(ОбъектДокумента.Ссылка);
	Если СтатусИзБазы <> Неопределено Тогда
		ОбъектДокумента.СтатусДокумента = СтатусИзБазы;
	КонецЕсли;
	
КонецПроцедуры

// Настройка управляемой формы документа (вызов из ПриСозданииНаСервере / ПриЧтенииНаСервере / ПослеЗаписиНаСервере / ПриОткрытии).
Процедура НастроитьЭлементыФормыДокументаПоСтатусу(УправляемаяФорма, ОбъектДокумента) Экспорт
	
	ПравоСтатус = ЕстьПравоИзмененияСтатусаДокумента();
	СтатусВып = СтатусВыполнено();
	ИмяРеквизита = ИмяРеквизитаСтатусаДокумента();
	
	Если ОбъектДокумента.СтатусДокумента = СтатусВып Тогда
		Если Не ПравоСтатус Тогда
			УправляемаяФорма.ТолькоПросмотр = Истина;
		Иначе
			УправляемаяФорма.ТолькоПросмотр = Ложь;
			УстановитьТолькоПросмотрПодчиненных(УправляемаяФорма.Элементы, Истина, ИмяРеквизита);
		КонецЕсли;
	Иначе
		УправляемаяФорма.ТолькоПросмотр = Ложь;
		УстановитьТолькоПросмотрПодчиненных(УправляемаяФорма.Элементы, Ложь, ИмяРеквизита);
	КонецЕсли;
	
	ПрименитьДоступностьКоВсемПолямСтатусаНаФорме(УправляемаяФорма, ПравоСтатус, ИмяРеквизита);
	
	Если ОбъектДокумента <> Неопределено Тогда
		ЗафиксироватьСтатусБезПраваИзменения(ОбъектДокумента);
	КонецЕсли;
	
КонецПроцедуры

// Имена элементов формы для разблокировки на клиенте (ПутьКДанным на клиенте недоступен у части элементов).
Функция ИменаЭлементовПолейСтатусаНаФорме(УправляемаяФорма) Экспорт
	
	Имена = Новый Массив;
	Поля = Новый Массив;
	СобратьПоляРедактируемогоСтатусаНаФорме(УправляемаяФорма.Элементы, ИмяРеквизитаСтатусаДокумента(), Поля);
	
	Для Каждого Поле Из Поля Цикл
		Если Имена.Найти(Поле.Имя) = Неопределено Тогда
			Имена.Добавить(Поле.Имя);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Имена;
	
КонецФункции

// Текст для кнопки «Проверка прав» — роль, найден ли элемент, флаги доступности.
Функция СтрокаДиагностикиПоляСтатусаНаФорме(УправляемаяФорма, ОбъектДокумента) Экспорт
	
	ПравоСтатус = ЕстьПравоИзмененияСтатусаДокумента();
	ИмяРеквизита = ИмяРеквизитаСтатусаДокумента();
	ПоляРедактирования = Новый Массив;
	ПоляПоСсылке = Новый Массив;
	СобратьПоляРедактируемогоСтатусаНаФорме(УправляемаяФорма.Элементы, ИмяРеквизита, ПоляРедактирования);
	СобратьПоляСтатусаПоСсылкеНаФорме(УправляемаяФорма.Элементы, ИмяРеквизита, ПоляПоСсылке);
	
	Строки = Новый Массив;
	Строки.Добавить("Роль """ + ИмяРолиИзменениеСтатуса() + """ в сеансе: " + ?(ПравоСтатус, "ДА", "НЕТ"));
	Если ОбъектДокумента <> Неопределено Тогда
		Строки.Добавить("Статус в Объект формы: " + Строка(ОбъектДокумента.СтатусДокумента));
		Строки.Добавить("Документ проведён: " + ?(ОбъектДокумента.Проведен, "Да", "Нет"));
	КонецЕсли;
	Строки.Добавить("Форма.ТолькоПросмотр: " + Строка(УправляемаяФорма.ТолькоПросмотр));
	Строки.Добавить("Поля для ввода (приоритет пути """ + ИмяРеквизитаФормыСтатуса() + """): " + Строка(ПоляРедактирования.Количество()));
	
	ПоляРеквизитФормы = Новый Массив;
	СобратьПоляПоПутиНаФорме(УправляемаяФорма.Элементы, ИмяРеквизитаФормыСтатуса(), ПоляРеквизитФормы);
	Если ПоляРеквизитФормы.Количество() = 0 И ОбъектДокумента <> Неопределено И ОбъектДокумента.Проведен Тогда
		Строки.Добавить("На проведённом документе поле ""Объект.СтатусДокумента"" часто не даёт ввод. Добавьте реквизит формы """
			+ ИмяРеквизитаФормыСтатуса() + """ и элемент с тем же путём.");
	КонецЕсли;
	
	Если ПоляРедактирования.Количество() = 0 Тогда
		Строки.Добавить("Нет поля для ввода! В расширении формы добавьте элемент с путём """
			+ ПутьКДаннымРедактируемогоСтатуса(ИмяРеквизита)
			+ """. Путь ""Объект.Ссылка." + ИмяРеквизита + """ только показывает статус из БД, изменить нельзя.");
	Иначе
		Для Каждого Поле Из ПоляРедактирования Цикл
			Строки.Добавить("  • " + Поле.Имя + ", путь """ + Поле.ПутьКДанным
				+ """, ТолькоПросмотр=" + Строка(Поле.ТолькоПросмотр) + ", Доступность=" + Строка(Поле.Доступность));
		КонецЦикла;
	КонецЕсли;
	
	Если ПоляПоСсылке.Количество() > 0 Тогда
		Строки.Добавить("Полей по ссылке (только просмотр, не для смены статуса): " + Строка(ПоляПоСсылке.Количество()));
	КонецЕсли;
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ИмяРеквизитаСтатусаДокумента()
	Возврат "СтатусДокумента";
КонецФункции

Функция ТекстБлокировкиОбменаДляСтатусаВыполнено()
	Возврат "Документ в статусе ""Выполнено"" не участвует в обмене данными. "
		+ "Изменения из другой информационной базы не принимаются.";
КонецФункции

// БСП: не регистрировать объект для выгрузки, пока в БП статус «Выполнено» (std 773).
Процедура ОтключитьРегистрациюДокументаВОбменеЕслиСтатусВыполнено(ТекущийОбъект, СтатусВБазе)
	
	Если ТекущийОбъект = Неопределено Или ТекущийОбъект.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	СтатусВып = СтатусВыполнено();
	Если СтатусВБазе = СтатусВып И ТекущийОбъект.СтатусДокумента = СтатусВып Тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("ОтключитьМеханизмРегистрацииОбъектов", Истина);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПрименитьДоступностьКоВсемПолямСтатусаНаФорме(УправляемаяФорма, ПравоСтатус, ИмяРеквизита)
	
	ПоляРедактирования = Новый Массив;
	СобратьПоляРедактируемогоСтатусаНаФорме(УправляемаяФорма.Элементы, ИмяРеквизита, ПоляРедактирования);
	
	Для Каждого Поле Из ПоляРедактирования Цикл
		Если ПравоСтатус Тогда
			РазблокироватьДоступностьРодителейПоля(Поле);
			Поле.ТолькоПросмотр = Ложь;
			Поле.Доступность = Истина;
		Иначе
			Поле.ТолькоПросмотр = Истина;
			Поле.Доступность = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	// Поля «Объект.Ссылка.СтатусДокумента» — отображение из БД, не редактируют документ.
	ПоляПоСсылке = Новый Массив;
	СобратьПоляСтатусаПоСсылкеНаФорме(УправляемаяФорма.Элементы, ИмяРеквизита, ПоляПоСсылке);
	Для Каждого Поле Из ПоляПоСсылке Цикл
		Поле.ТолькоПросмотр = Истина;
	КонецЦикла;
	
КонецПроцедуры

Процедура РазблокироватьДоступностьРодителейПоля(ПолеФормы)
	
	Родитель = ПолеФормы.Родитель;
	Пока Родитель <> Неопределено Цикл
		
		ТипРодителя = ТипЗнч(Родитель);
		Если ТипРодителя = Тип("ГруппаФормы")
			Или ТипРодителя = Тип("СтраницаФормы")
			Или ТипРодителя = Тип("СтраницыФормы") Тогда
			Родитель.Доступность = Истина;
			Родитель.ТолькоПросмотр = Ложь;
		КонецЕсли;
		
		// У корня формы (и у части контейнеров) свойства Родитель нет — не обращаться повторно.
		СледующийРодитель = Неопределено;
		Попытка
			СледующийРодитель = Родитель.Родитель;
		Исключение
			Прервать;
		КонецПопытки;
		Родитель = СледующийРодитель;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПутьКДаннымРедактируемогоСтатуса(ИмяРеквизита)
	Возврат "Объект." + ИмяРеквизита;
КонецФункции

Процедура СобратьПоляРедактируемогоСтатусаНаФорме(КоллекцияЭлементов, ИмяРеквизита, ПоляСтатуса)
	
	ПоляРеквизитФормы = Новый Массив;
	ПоляОбъект = Новый Массив;
	ПоляЗапасные = Новый Массив;
	СобратьКандидатыРедактируемогоСтатуса(КоллекцияЭлементов, ИмяРеквизита, ПоляРеквизитФормы, ПоляОбъект, ПоляЗапасные);
	
	Если ПоляРеквизитФормы.Количество() > 0 Тогда
		Для Каждого Поле Из ПоляРеквизитФормы Цикл
			ПоляСтатуса.Добавить(Поле);
		КонецЦикла;
	ИначеЕсли ПоляОбъект.Количество() > 0 Тогда
		Для Каждого Поле Из ПоляОбъект Цикл
			ПоляСтатуса.Добавить(Поле);
		КонецЦикла;
	Иначе
		Для Каждого Поле Из ПоляЗапасные Цикл
			ПоляСтатуса.Добавить(Поле);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура СобратьПоляПоПутиНаФорме(КоллекцияЭлементов, ИмяПути, Поля)
	
	ПутьВрег = ВРег(ИмяПути);
	Для Каждого Элемент Из КоллекцияЭлементов Цикл
		ТипЭлемента = ТипЗнч(Элемент);
		Если ТипЭлемента = Тип("ПолеФормы") И ВРег(Элемент.ПутьКДанным) = ПутьВрег Тогда
			Поля.Добавить(Элемент);
		ИначеЕсли ТипЭлемента = Тип("ГруппаФормы")
			Или ТипЭлемента = Тип("СтраницаФормы")
			Или ТипЭлемента = Тип("СтраницыФормы")
			Или ТипЭлемента = Тип("ТаблицаФормы") Тогда
			СобратьПоляПоПутиНаФорме(Элемент.ПодчиненныеЭлементы, ИмяПути, Поля);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура СобратьКандидатыРедактируемогоСтатуса(КоллекцияЭлементов, ИмяРеквизита, ПоляРеквизитФормы, ПоляОбъект, ПоляЗапасные)
	
	ПутьОбъектВрег = ВРег(ПутьКДаннымРедактируемогоСтатуса(ИмяРеквизита));
	ПутьРеквизитФормыВрег = ВРег(ИмяРеквизитаФормыСтатуса());
	
	Для Каждого Элемент Из КоллекцияЭлементов Цикл
		
		ТипЭлемента = ТипЗнч(Элемент);
		
		Если ТипЭлемента = Тип("ПолеФормы") Тогда
			Если ЭтоПолеРедактируемогоСтатусаНаФорме(Элемент, ИмяРеквизита) Тогда
				ПутьВрег = ВРег(Элемент.ПутьКДанным);
				Если ПутьВрег = ПутьРеквизитФормыВрег Тогда
					ПоляРеквизитФормы.Добавить(Элемент);
				ИначеЕсли ПутьВрег = ПутьОбъектВрег Тогда
					ПоляОбъект.Добавить(Элемент);
				Иначе
					ПоляЗапасные.Добавить(Элемент);
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли ТипЭлемента = Тип("ГруппаФормы")
			Или ТипЭлемента = Тип("СтраницаФормы")
			Или ТипЭлемента = Тип("СтраницыФормы")
			Или ТипЭлемента = Тип("ТаблицаФормы") Тогда
			СобратьКандидатыРедактируемогоСтатуса(Элемент.ПодчиненныеЭлементы, ИмяРеквизита, ПоляРеквизитФормы, ПоляОбъект, ПоляЗапасные);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СобратьПоляСтатусаПоСсылкеНаФорме(КоллекцияЭлементов, ИмяРеквизита, ПоляПоСсылке)
	
	Для Каждого Элемент Из КоллекцияЭлементов Цикл
		
		ТипЭлемента = ТипЗнч(Элемент);
		
		Если ТипЭлемента = Тип("ПолеФормы") Тогда
			Если ЭтоПолеСтатусаПоСсылкеТолькоПросмотр(Элемент, ИмяРеквизита) Тогда
				ПоляПоСсылке.Добавить(Элемент);
			КонецЕсли;
		ИначеЕсли ТипЭлемента = Тип("ГруппаФормы")
			Или ТипЭлемента = Тип("СтраницаФормы")
			Или ТипЭлемента = Тип("СтраницыФормы")
			Или ТипЭлемента = Тип("ТаблицаФормы") Тогда
			СобратьПоляСтатусаПоСсылкеНаФорме(Элемент.ПодчиненныеЭлементы, ИмяРеквизита, ПоляПоСсылке);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ЭтоПолеСтатусаПоСсылкеТолькоПросмотр(Элемент, ИмяРеквизита)
	
	Если ТипЗнч(Элемент) <> Тип("ПолеФормы") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПутьВрег = ВРег(Элемент.ПутьКДанным);
	ИмяВрег = ВРег(ИмяРеквизита);
	
	Возврат СтрНайти(ПутьВрег, ".ССЫЛКА.") > 0
		И (ПутьВрег = "ОБЪЕКТ.ССЫЛКА." + ИмяВрег Или СтрЗаканчиваетсяНа(ПутьВрег, ".ССЫЛКА." + ИмяВрег));
	
КонецФункции

Функция ЭтоПолеРедактируемогоСтатусаНаФорме(Элемент, ИмяРеквизита)
	
	Если ТипЗнч(Элемент) <> Тип("ПолеФормы") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЭтоПолеСтатусаПоСсылкеТолькоПросмотр(Элемент, ИмяРеквизита) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ИмяВрег = ВРег(ИмяРеквизита);
	ПутьВрег = ВРег(Элемент.ПутьКДанным);
	ПутьОбъектВрег = ВРег(ПутьКДаннымРедактируемогоСтатуса(ИмяРеквизита));
	ПутьРеквизитФормыВрег = ВРег(ИмяРеквизитаФормыСтатуса());
	
	Если ПутьВрег = ПутьРеквизитФормыВрег Или ПутьВрег = ПутьОбъектВрег Тогда
		Возврат Истина;
	КонецЕсли;
	
	// Реквизит формы без «Объект.» — только если нет поля Объект.СтатусДокумента (см. приоритет в сборе).
	Если ПутьВрег = ИмяВрег Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ПустаяСтрока(Элемент.ПутьКДанным)
		И ИмяЭлементаСовпадаетСРеквизитомСтатусаПоСоглашению(Элемент.Имя, ИмяРеквизита) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Для обратной совместимости вызовов внутри модуля.
Функция ЭтоПолеСтатусаДокументаНаФорме(Элемент, ИмяРеквизита)
	Возврат ЭтоПолеРедактируемогоСтатусаНаФорме(Элемент, ИмяРеквизита);
КонецФункции

Функция ЭлементПоляСтатусаДокументаНаФорме(УправляемаяФорма)
	
	Попытка
		Кандидат = УправляемаяФорма.Элементы.СтатусДокумента;
		Если ТипЗнч(Кандидат) = Тип("ПолеФормы") Тогда
			Возврат Кандидат;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	// Типовые формы часто дают имя вроде СтатусДокумента1 из‑за коллизии имён при расширении.
	Попытка
		Кандидат = УправляемаяФорма.Элементы.СтатусДокумента1;
		Если ТипЗнч(Кандидат) = Тип("ПолеФормы") Тогда
			Возврат Кандидат;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Поля = Новый Массив;
	СобратьПоляРедактируемогоСтатусаНаФорме(УправляемаяФорма.Элементы, ИмяРеквизитаСтатусаДокумента(), Поля);
	Если Поля.Количество() > 0 Тогда
		Возврат Поля[0];
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ИмяЭлементаСовпадаетСРеквизитомСтатусаПоСоглашению(ИмяЭлемента, ИмяРеквизита)
	
	РеквВрег = ВРег(ИмяРеквизита);
	ИмяВрег = ВРег(ИмяЭлемента);
	Если ИмяВрег = РеквВрег Тогда
		Возврат Истина;
	КонецЕсли;
	Если Не СтрНачинаетсяС(ИмяВрег, РеквВрег) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Хвост = Сред(ИмяЭлемента, СтрДлина(ИмяРеквизита) + 1);
	Если ПустаяСтрока(Хвост) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Для Инд = 1 По СтрДлина(Хвост) Цикл
		Если Найти("0123456789", Сред(Хвост, Инд, 1)) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция НайтиПолеФормыПоРеквизитуШапки(КоллекцияЭлементов, ИмяРеквизита)
	
	Для Каждого Элемент Из КоллекцияЭлементов Цикл
		
		ТипЭлемента = ТипЗнч(Элемент);
		
		Если ТипЭлемента = Тип("ПолеФормы") Тогда
			
			Если ЭтоПолеСтатусаДокументаНаФорме(Элемент, ИмяРеквизита) Тогда
				Возврат Элемент;
			КонецЕсли;
			
		ИначеЕсли ТипЭлемента = Тип("ГруппаФормы")
			Или ТипЭлемента = Тип("СтраницаФормы")
			Или ТипЭлемента = Тип("СтраницыФормы")
			Или ТипЭлемента = Тип("ТаблицаФормы") Тогда
			
			Найденный = НайтиПолеФормыПоРеквизитуШапки(Элемент.ПодчиненныеЭлементы, ИмяРеквизита);
			Если Найденный <> Неопределено Тогда
				Возврат Найденный;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

Функция СтатусДокументаИзБазы(СсылкаДокумента, ИмяДокументаМетаданных)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Т.СтатусДокумента КАК СтатусДокумента
	|ИЗ
	|	Документ." + ИмяДокументаМетаданных + " КАК Т
	|ГДЕ
	|	Т.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", СсылкаДокумента);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	Выборка = Результат.Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.СтатусДокумента;
	КонецЕсли;
	Возврат Неопределено;
	
КонецФункции

Функция ДокументыСтруктурноСовпадают(ОбъектА, ОбъектБ, ИмяДокументаМетаданных, СравниватьТабличныеЧасти = Истина)
	
	МД = Метаданные.Документы[ИмяДокументаМетаданных];
	
	Для Каждого Рек Из МД.Реквизиты Цикл
		Если ВРег(Рек.Имя) = ВРег("СтатусДокумента") Тогда
			Продолжить;
		КонецЕсли;
		Если ОбъектА[Рек.Имя] <> ОбъектБ[Рек.Имя] Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	// Стандартные реквизиты документа (без Ссылки).
	Если ОбъектА.Дата <> ОбъектБ.Дата Тогда
		Возврат Ложь;
	КонецЕсли;
	Если ОбъектА.Номер <> ОбъектБ.Номер Тогда
		Возврат Ложь;
	КонецЕсли;
	Если ОбъектА.ПометкаУдаления <> ОбъектБ.ПометкаУдаления Тогда
		Возврат Ложь;
	КонецЕсли;
	Если ОбъектА.Проведен <> ОбъектБ.Проведен Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Не СравниватьТабличныеЧасти Тогда
		Возврат Истина;
	КонецЕсли;
	
	Для Каждого ТчМд Из МД.ТабличныеЧасти Цикл
		ИмяТч = ТчМд.Имя;
		ТзА = ОбъектА[ИмяТч].Выгрузить();
		ТзБ = ОбъектБ[ИмяТч].Выгрузить();
		Если ТзА.Количество() <> ТзБ.Количество() Тогда
			Возврат Ложь;
		КонецЕсли;
		Для Инд = 0 По ТзА.Количество() - 1 Цикл
			Для Каждого Кол Из ТзА.Колонки Цикл
				Если ВРег(Кол.Имя) = ВРег("НомерСтроки") Тогда
					Продолжить;
				КонецЕсли;
				Если ТзА[Инд][Кол.Имя] <> ТзБ[Инд][Кол.Имя] Тогда
					Возврат Ложь;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Процедура УстановитьТолькоПросмотрПодчиненных(КоллекцияЭлементов, ТолькоПросмотр, ИмяРеквизита)
	
	Для Каждого Элемент Из КоллекцияЭлементов Цикл
		
		ТипЭлемента = ТипЗнч(Элемент);
		
		Если ТипЭлемента = Тип("ГруппаФормы")
			Или ТипЭлемента = Тип("СтраницаФормы")
			Или ТипЭлемента = Тип("СтраницыФормы") Тогда
			
			УстановитьТолькоПросмотрПодчиненных(Элемент.ПодчиненныеЭлементы, ТолькоПросмотр, ИмяРеквизита);
			
		ИначеЕсли ТипЭлемента = Тип("ТаблицаФормы") Тогда
			
			Элемент.ТолькоПросмотр = ТолькоПросмотр;
			
		ИначеЕсли ТипЭлемента = Тип("ПолеФормы") Тогда
			
			Если Не ЭтоПолеСтатусаДокументаНаФорме(Элемент, ИмяРеквизита) Тогда
				Элемент.ТолькоПросмотр = ТолькоПросмотр;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
